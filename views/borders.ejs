<!doctype html>
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>Border Management</title>
<style>
body{font-family:Arial,sans-serif;background:#f6f7f9;margin:0;padding:24px;color:#171b25}h1{color:#ff2d2d}.card{background:#fff;padding:20px;border-radius:16px;margin-bottom:18px;box-shadow:0 8px 28px rgba(16,24,40,.06)}form{display:flex;gap:12px;flex-wrap:wrap;align-items:end}label{font-weight:700;font-size:13px}input,select,button{padding:11px;border:1px solid #dfe3ea;border-radius:9px;background:#fff}button{cursor:pointer;font-weight:700}.primary{background:#ff2d2d;color:#fff;border-color:#ff2d2d}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px}.item{background:#fff;border:1px solid #eceef2;border-radius:14px;padding:12px}.item img{width:100%;height:125px;object-fit:contain;background:#fafafa;border-radius:9px}.tag{display:inline-block;padding:4px 8px;border-radius:999px;font-size:11px;font-weight:800;margin-top:6px}.free{background:#dcfce7;color:#166534}.premium{background:#fff0c2;color:#8a5a00}.business{background:#ebe5ff;color:#5634c9}.actions{display:flex;gap:7px;margin-top:10px}.actions form{margin:0}.hint{color:#667085;line-height:1.5}
</style></head><body>
<h1>Easy Label Borders</h1>
<div class="card"><h2>Upload Border</h2><p class="hint">Upload a transparent black SVG, PNG or JPG. Set access to Free, Premium ₹99/₹299, or Business ₹299 only.</p>
<form action="/api/borders/admin/upload" method="post" enctype="multipart/form-data">
<label>Name<br><input name="name" required></label>
<label>Category<br><select name="category"><option>new</option><option>hot</option><option>fancy</option><option>plant</option><option>holiday</option><option>animal</option></select></label>
<label>Plan access<br><select name="accessLevel"><option value="premium" selected>Premium ₹99 + Business ₹299</option><option value="business">Business ₹299 only</option><option value="free">Free users</option></select></label>
<label>Order<br><input name="sortOrder" type="number" value="0"></label>
<input name="border" type="file" accept="image/svg+xml,image/png,image/jpeg,.svg,.png,.jpg,.jpeg" required>
<button class="primary">Upload Border</button></form></div>
<div class="grid"><% borders.forEach(b=>{ const level=b.accessLevel||'free'; %>
<div class="item"><img src="<%= b.thumbnailUrl || b.imageUrl %>" alt="<%= b.name %>"><h3><%= b.name %></h3><div><%= b.category %></div><span class="tag <%= level %>"><%= level==='business'?'BUSINESS ₹299':level==='premium'?'PREMIUM ₹99/₹299':'FREE' %></span><div><%= b.active?'Active':'Disabled' %></div><div class="actions"><form action="/api/borders/admin/<%= b._id %>/toggle" method="post"><button>Enable/Disable</button></form><form action="/api/borders/admin/<%= b._id %>/delete" method="post" onsubmit="return confirm('Delete border?')"><button>Delete</button></form></div></div>
<% }) %></div></body></html>
