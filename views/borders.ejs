<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>Border Management</title><style>body{font-family:Arial;background:#f6f7f9;margin:0;padding:24px}h1{color:#ff2d2d}.card{background:#fff;padding:20px;border-radius:16px;margin-bottom:18px}form{display:flex;gap:10px;flex-wrap:wrap;align-items:end}input,select,button{padding:10px;border:1px solid #ddd;border-radius:8px}button{cursor:pointer}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px}.item{background:#fff;border:1px solid #eee;border-radius:14px;padding:12px}.item img{width:100%;height:110px;object-fit:contain}.vip{color:#a86a00;font-weight:bold}</style></head><body><h1>Easy Label Borders</h1><div class="card"><h2>Upload Border</h2><p>Upload an SVG, transparent PNG, JPG or JPEG border. SVG is recommended for sharp scaling. Maximum file size: 10 MB.</p><form action="/api/borders/admin/upload" method="post" enctype="multipart/form-data"><label>Name<br><input name="name" required></label><label>Category<br><select name="category"><option>new</option><option>hot</option><option>fancy</option><option>plant</option><option>holiday</option><option>animal</option></select></label><label>Order<br><input name="sortOrder" type="number" value="0"></label><label><input name="isVip" type="checkbox"> VIP</label><input name="border" type="file" accept="image/svg+xml,image/png,image/jpeg,.svg,.png,.jpg,.jpeg" required><button>Upload</button></form></div><div class="grid"><% borders.forEach(b=>{ %><div class="item"><img src="<%= b.imageUrl %>"><b><%= b.name %></b><div><%= b.category %> <span class="vip"><%= b.isVip?'VIP':'' %></span></div><div><%= b.active?'Active':'Disabled' %></div><form action="/api/borders/admin/<%= b._id %>/toggle" method="post"><button>Enable/Disable</button></form><form action="/api/borders/admin/<%= b._id %>/delete" method="post" onsubmit="return confirm('Delete border?')"><button>Delete</button></form></div><% }) %></div></body></html>