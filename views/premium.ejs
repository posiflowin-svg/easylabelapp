<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Subscription Management - EasyLabel</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0;font-family:Arial,sans-serif}body{display:flex;min-height:100vh;background:#f4f6fb;color:#1f2937}.sidebar{width:280px;background:#2c3e50;color:#fff;padding:26px 18px;position:fixed;height:100vh;overflow:auto}.sidebar h1{text-align:center;margin-bottom:28px}.sidebar a{display:block;color:#cbd5e1;text-decoration:none;padding:13px 14px;border-radius:9px;margin:5px 0}.sidebar a:hover,.sidebar a.active{background:#1abc9c;color:#fff}.sidebar .section{font-size:12px;text-transform:uppercase;letter-spacing:1px;color:#94a3b8;margin:22px 12px 8px}.main{margin-left:280px;padding:34px;width:calc(100% - 280px)}.topbar{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:26px}.topbar h2{font-size:30px}.topbar p{color:#64748b;margin-top:6px}.badge{background:#ecfdf5;color:#047857;border:1px solid #a7f3d0;padding:8px 12px;border-radius:999px;font-weight:700}.cards{display:grid;grid-template-columns:repeat(4,minmax(180px,1fr));gap:16px;margin-bottom:18px}.card{background:#fff;border-radius:14px;padding:20px;box-shadow:0 3px 14px rgba(15,23,42,.07);border:1px solid #e5e7eb}.card small{color:#64748b}.card strong{display:block;font-size:28px;margin-top:10px}.card i{float:right;color:#2563eb}.panel{display:none}.panel.active{display:block}.section-card{background:#fff;border-radius:14px;padding:22px;box-shadow:0 3px 14px rgba(15,23,42,.07);border:1px solid #e5e7eb;margin-bottom:20px}.section-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}.section-head h3{font-size:20px}.muted{color:#64748b;font-size:14px}.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:18px}.plan{border:1px solid #dbeafe;border-radius:14px;padding:20px;background:linear-gradient(180deg,#fff,#f8fbff)}.plan.recommended{border:2px solid #2563eb}.plan h3{font-size:22px}.price{font-size:34px;font-weight:800;margin:10px 0}.price span{font-size:14px;color:#64748b}.features{margin:14px 0 18px}.features li{list-style:none;margin:9px 0;color:#334155}.features i{color:#16a34a;margin-right:8px}table{width:100%;border-collapse:collapse}th,td{padding:13px 10px;border-bottom:1px solid #e5e7eb;text-align:left;font-size:14px}th{background:#f8fafc;color:#475569}.status{padding:5px 9px;border-radius:999px;font-size:12px;font-weight:700}.on{background:#dcfce7;color:#166534}.off{background:#fee2e2;color:#991b1b}.warn{background:#fef3c7;color:#92400e}.btn{border:0;border-radius:8px;padding:9px 13px;cursor:pointer;font-weight:700}.btn-primary{background:#2563eb;color:#fff}.btn-danger{background:#dc2626;color:#fff}.btn-secondary{background:#e2e8f0;color:#334155}.btn-success{background:#16a34a;color:#fff}.btn-sm{padding:7px 10px;font-size:12px}input,select,textarea{width:100%;padding:10px;border:1px solid #cbd5e1;border-radius:8px;font-size:14px}label{display:block;font-size:13px;font-weight:700;margin:9px 0 5px}.form-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.form-actions{margin-top:15px}.inline{display:flex;align-items:center;gap:8px}.inline input[type=checkbox]{width:auto}.feature-checks{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.feature-checks label{font-weight:500;margin:0;display:flex;gap:8px;align-items:center}.feature-checks input{width:auto}.notice{padding:12px 14px;border-radius:9px;margin-bottom:15px;display:none}.notice.ok{display:block;background:#dcfce7;color:#166534}.notice.err{display:block;background:#fee2e2;color:#991b1b}.toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center}.toolbar input,.toolbar select{max-width:250px}.table-wrap{overflow:auto}.action-row{display:flex;gap:7px;align-items:center;min-width:245px}.action-row input{width:80px}.nowrap{white-space:nowrap}.mini{font-size:12px;color:#64748b}.metric-note{margin-top:8px;color:#64748b;font-size:12px}
    @media(max-width:1100px){.cards{grid-template-columns:repeat(2,1fr)}.grid-2{grid-template-columns:1fr}.form-grid{grid-template-columns:1fr 1fr}}@media(max-width:700px){.sidebar{position:relative;width:100%;height:auto}.main{margin-left:0;width:100%;padding:18px}body{display:block}.cards{grid-template-columns:1fr}.form-grid,.feature-checks{grid-template-columns:1fr}}
  </style>
</head>
<body>
<aside class="sidebar">
  <h1>EasyLabel</h1>
  <a href="/"><i class="fas fa-arrow-left"></i> Back to Dashboard</a>
  <div class="section">Subscription Management</div>
  <a href="#" class="active" onclick="openTab('overview',this)"><i class="fas fa-chart-pie"></i> Dashboard</a>
  <a href="#" onclick="openTab('plans',this)"><i class="fas fa-layer-group"></i> Subscription Plans</a>
  <a href="#" onclick="openTab('features',this)"><i class="fas fa-toggle-on"></i> Premium Features</a>
  <a href="#" onclick="openTab('subscriptions',this)"><i class="fas fa-users"></i> User Subscriptions</a>
  <div class="section">Content & Marketing</div>
  <a href="#" onclick="openTab('campaigns',this)"><i class="fas fa-bullhorn"></i> Campaign Manager</a>
  <a href="#" onclick="openTab('notifications',this)"><i class="fas fa-bell"></i> Push Notifications</a>
  <div class="section">Insights & Settings</div>
  <a href="#" onclick="openTab('analytics',this)"><i class="fas fa-chart-line"></i> Analytics</a>
  <a href="#" onclick="openTab('aiusage',this)"><i class="fas fa-wand-magic-sparkles"></i> AI Usage</a>
  <a href="#" onclick="openTab('settings',this)"><i class="fas fa-gear"></i> Settings</a>
</aside>

<main class="main">
  <div class="topbar"><div><h2>Subscription Management</h2><p>Phase 1.3 professional administration. All current EasyLabel features remain free and unchanged.</p></div><span class="badge"><i class="fas fa-shield-alt"></i> Foundation Active</span></div>
  <div id="message" class="notice"></div>

  <section id="overview" class="panel active">
    <div class="cards">
      <div class="card"><i class="fas fa-users"></i><small>Total Users</small><strong><%= stats.totalUsers %></strong><div class="metric-note">Free users: <%= stats.freeUsers %></div></div>
      <div class="card"><i class="fas fa-user-check"></i><small>Active Subscriptions</small><strong><%= stats.active %></strong><div class="metric-note">Trials: <%= stats.trialCount %></div></div>
      <div class="card"><i class="fas fa-clock"></i><small>Expiring in 7 Days</small><strong><%= stats.expiringSoon %></strong><div class="metric-note">Expired records: <%= stats.expiredCount %></div></div>
      <div class="card"><i class="fas fa-indian-rupee-sign"></i><small>Estimated Monthly Revenue</small><strong>₹<%= stats.estimatedMrr %></strong></div>
    </div>
    <div class="cards">
      <div class="card"><i class="fas fa-crown"></i><small>₹99 Premium Users</small><strong><%= stats.premiumCount %></strong></div>
      <div class="card"><i class="fas fa-building"></i><small>₹299 Business Users</small><strong><%= stats.businessCount %></strong></div>
    </div>
    <div class="section-card"><div class="section-head"><div><h3>Plan Overview</h3><p class="muted">Commercial structure currently served to the Android app through the catalog API.</p></div></div><div class="grid-2">
      <% plans.forEach(plan => { %><div class="plan <%= plan.recommended ? 'recommended' : '' %>"><h3><%= plan.name %></h3><div class="price">₹<%= plan.price %><span>/<%= plan.billingPeriod %></span></div><p class="muted"><%= plan.description || '' %></p><ul class="features"><% plan.featureKeys.forEach(key => { const f=features.find(x=>x.key===key); %><li><i class="fas fa-check-circle"></i><%= f ? f.name : key %></li><% }) %></ul><span class="status <%= plan.active ? 'on':'off' %>"><%= plan.active ? 'ACTIVE':'INACTIVE' %></span></div><% }) %>
    </div></div>
  </section>

  <section id="plans" class="panel">
    <div class="section-card"><div class="section-head"><div><h3>Create Subscription Plan</h3><p class="muted">Create future monthly, yearly, dealer or enterprise plans without changing app code.</p></div></div>
      <form onsubmit="createPlan(event)"><div class="form-grid"><div><label>Plan Key</label><input name="key" placeholder="premium_yearly" required></div><div><label>Plan Name</label><input name="name" placeholder="EasyLabel Premium Yearly" required></div><div><label>Badge</label><input name="badgeText" placeholder="BEST VALUE"></div></div><div class="form-grid"><div><label>Monthly Price (₹)</label><input name="price" type="number" min="0" value="0" required></div><div><label>Yearly Price (₹)</label><input name="yearlyPrice" type="number" min="0" value="0"></div><div><label>Billing Period</label><select name="billingPeriod"><option value="monthly">Monthly</option><option value="yearly">Yearly</option><option value="lifetime">Lifetime</option></select></div></div><label>Description</label><textarea name="description" rows="2"></textarea><div class="feature-checks"><% features.forEach(feature=>{ %><label><input type="checkbox" name="featureKeys" value="<%=feature.key%>"> <%=feature.name%></label><% }) %></div><div class="inline" style="margin-top:12px"><input type="checkbox" name="autoRenew" checked> Auto Renew <input type="checkbox" name="active" checked style="margin-left:18px"> Active</div><div class="form-actions"><button class="btn btn-primary">Create Plan</button></div></form>
    </div>
    <div class="section-card"><div class="section-head"><div><h3>Subscription Plans</h3><p class="muted">Edit price, billing, included features and limits. Existing free app features are not affected.</p></div></div><div class="grid-2">
    <% plans.forEach(plan => { %><form class="plan plan-form <%= plan.recommended ? 'recommended':'' %>" onsubmit="savePlan(event,'<%= plan._id %>')">
      <h3><%= plan.name %></h3>
      <label>Plan Name</label><input name="name" value="<%= plan.name %>" required>
      <label>Description</label><textarea name="description" rows="2"><%= plan.description || '' %></textarea><label>Badge Text</label><input name="badgeText" value="<%= plan.badgeText || '' %>" placeholder="BEST VALUE">
      <div class="form-grid"><div><label>Monthly Price (₹)</label><input name="price" type="number" min="0" value="<%= plan.price %>" required></div><div><label>Yearly Price (₹)</label><input name="yearlyPrice" type="number" min="0" value="<%= plan.yearlyPrice || 0 %>"></div><div><label>Trial Days</label><input name="freeTrialDays" type="number" min="0" value="<%= plan.freeTrialDays || 0 %>"></div></div><div class="form-grid"><div><label>Billing Period</label><select name="billingPeriod"><option value="monthly" <%=plan.billingPeriod==='monthly'?'selected':''%>>Monthly</option><option value="yearly" <%=plan.billingPeriod==='yearly'?'selected':''%>>Yearly</option><option value="lifetime" <%=plan.billingPeriod==='lifetime'?'selected':''%>>Lifetime</option></select></div><div><label>Display Order</label><input name="displayOrder" type="number" min="0" value="<%= plan.displayOrder || 0 %>"></div></div>
      <div class="form-grid"><div><label>AI Designs / Month</label><input name="aiMonthlyLimit" type="number" min="0" value="<%= plan.aiMonthlyLimit %>"></div><div><label>Team Member Limit</label><input name="teamMemberLimit" type="number" min="1" value="<%= plan.teamMemberLimit %>"></div><div><label>Status</label><select name="active"><option value="true" <%=plan.active?'selected':''%>>Active</option><option value="false" <%=!plan.active?'selected':''%>>Inactive</option></select></div></div>
      <label>Included Premium Features</label><div class="feature-checks"><% features.forEach(feature=>{ %><label><input type="checkbox" name="featureKeys" value="<%=feature.key%>" <%=plan.featureKeys.includes(feature.key)?'checked':''%>> <%=feature.name%></label><% }) %></div>
      <label>Google Play Product ID</label><input name="googleProductId" value="<%= plan.googleProductId || '' %>" placeholder="Add during Phase 2">
      <label>Google Play Base Plan ID</label><input name="googleBasePlanId" value="<%= plan.googleBasePlanId || '' %>" placeholder="Add during Phase 2">
      <div class="inline"><input type="checkbox" name="autoRenew" value="true" <%=plan.autoRenew?'checked':''%>><label style="margin:0">Auto-renew subscription</label></div>
      <div class="inline"><input type="checkbox" name="recommended" value="true" <%=plan.recommended?'checked':''%>><label style="margin:0">Recommended Plan</label></div>
      <div class="form-actions"><button class="btn btn-primary">Save Plan</button> <button type="button" class="btn btn-danger" onclick="deletePlan('<%=plan._id%>')">Delete</button></div>
    </form><% }) %>
  </div></div></section>

  <section id="features" class="panel">
    <div class="section-card">
      <div class="section-head"><div><h3>Create Premium Feature</h3><p class="muted">Add a new paid capability using a stable feature key. Current free features remain unchanged.</p></div></div>
      <form onsubmit="createFeature(event)">
        <div class="form-grid">
          <div><label>Feature Key</label><input name="key" placeholder="advanced_barcode_tools" required></div>
          <div><label>Feature Name</label><input name="name" placeholder="Advanced Barcode Tools" required></div>
          <div><label>Category</label><select name="category"><option value="design">Design</option><option value="content">Content</option><option value="ai">AI</option><option value="cloud">Cloud</option><option value="team">Team</option><option value="other">Other</option></select></div>
        </div>
        <label>Description</label><textarea name="description" rows="2"></textarea>
        <div class="inline" style="margin-top:12px"><input type="checkbox" name="enabled" checked> Enabled</div>
        <div class="form-actions"><button class="btn btn-primary">Create Feature</button></div>
      </form>
    </div>
    <div class="section-card">
      <div class="section-head"><div><h3>Premium Feature Controls</h3><p class="muted">A feature switched OFF is disabled for every plan through the entitlement API.</p></div></div>
      <div class="table-wrap"><table><thead><tr><th>Feature</th><th>Key</th><th>Category</th><th>Description</th><th>Order</th><th>Status</th><th>Actions</th></tr></thead><tbody>
      <% features.forEach(feature => { %>
        <tr><td><strong><%= feature.name %></strong></td><td><code><%= feature.key %></code></td><td><%= feature.category || 'other' %></td><td><%= feature.description %></td><td><%= feature.displayOrder %></td><td><span class="status <%=feature.enabled?'on':'off'%>"><%=feature.enabled?'ON':'OFF'%></span></td><td><button class="btn btn-sm <%=feature.enabled?'btn-danger':'btn-success'%>" onclick="toggleFeature('<%=feature._id%>',<%=!feature.enabled%>)"><%=feature.enabled?'Turn OFF':'Turn ON'%></button> <button class="btn btn-sm btn-danger" onclick="deleteFeature('<%=feature._id%>')">Delete</button></td></tr>
      <% }) %>
      </tbody></table></div>
    </div>
  </section>

  <section id="subscriptions" class="panel">
    <div class="section-card"><div class="section-head"><div><h3>Manual Subscription Activation</h3><p class="muted">Use for internal testing, complimentary access or support cases before Google Play Billing is connected.</p></div></div><form id="subscriptionForm" onsubmit="createSubscription(event)"><div class="form-grid"><div><label>User</label><select name="userId" required><option value="">Select user</option><% users.forEach(u=>{ %><option value="<%=u._id%>"><%=u.name || 'Unnamed'%> — <%=u.phone || u.email || u._id%></option><% }) %></select></div><div><label>Plan</label><select name="planKey" required><% plans.forEach(p=>{ %><option value="<%=p.key%>"><%=p.name%> — ₹<%=p.price%>/<%=p.billingPeriod%></option><% }) %></select></div><div><label>Status</label><select name="status"><option value="active">Active</option><option value="trial">Trial</option></select></div></div><div class="form-grid"><div><label>Access Valid Until</label><input type="date" name="expiryDate" required></div><div class="inline" style="margin-top:30px"><input type="checkbox" name="autoRenew" value="true"><label style="margin:0">Auto Renew (testing display only)</label></div></div><label>Admin Notes</label><textarea name="notes" rows="2" placeholder="Reason for manual activation"></textarea><div class="form-actions"><button class="btn btn-primary">Activate Subscription</button></div></form></div>

    <div class="section-card"><div class="section-head"><div><h3>User Subscriptions</h3><p class="muted">Search, filter, extend, cancel or reactivate subscription access.</p></div><div class="toolbar"><input id="subSearch" placeholder="Search name, phone, email or plan" oninput="filterSubscriptions()"><select id="subStatus" onchange="filterSubscriptions()"><option value="">All statuses</option><option value="active">Active</option><option value="trial">Trial</option><option value="cancelled">Cancelled</option><option value="expired">Expired</option><option value="revoked">Revoked</option></select></div></div><div class="table-wrap"><table id="subscriptionTable"><thead><tr><th>User</th><th>Plan</th><th>Source</th><th>Start</th><th>Expiry</th><th>Auto Renew</th><th>Status</th><th>Actions</th></tr></thead><tbody><% if(!subscriptions.length){ %><tr><td colspan="8" class="muted">No subscriptions created yet.</td></tr><% } subscriptions.forEach(s=>{ const searchable=((s.userId?.name||'')+' '+(s.userId?.phone||'')+' '+(s.userId?.email||'')+' '+s.planKey).toLowerCase(); %><tr data-search="<%=searchable%>" data-status="<%=s.status%>"><td><strong><%=s.userId?.name || 'Unknown User'%></strong><br><small><%=s.userId?.phone || s.userId?.email || ''%></small></td><td><%=s.planKey%></td><td><%=s.source%></td><td class="nowrap"><%=new Date(s.startDate).toLocaleDateString('en-IN')%></td><td class="nowrap"><%=new Date(s.expiryDate).toLocaleDateString('en-IN')%></td><td><%=s.autoRenew?'Yes':'No'%></td><td><span class="status <%=['active','trial','grace_period'].includes(s.status)?'on':(s.status==='payment_pending'?'warn':'off')%>"><%=s.status%></span></td><td><div class="action-row"><select onchange="changeStatus('<%=s._id%>',this.value)"><option value="">Status</option><option value="active">Active</option><option value="cancelled">Cancelled</option><option value="expired">Expired</option><option value="refunded">Refunded</option><option value="revoked">Revoked</option></select><input id="days-<%=s._id%>" type="number" min="1" value="30" title="Extension days"><button class="btn btn-sm btn-secondary" onclick="extendSubscription('<%=s._id%>')">Extend</button><button class="btn btn-sm btn-secondary" onclick="recordPayment('<%=s._id%>')">Payment</button><button class="btn btn-sm btn-danger" onclick="deleteSubscription('<%=s._id%>')">Delete</button></div></td></tr><% }) %></tbody></table></div></div>
  </section>


  <section id="campaigns" class="panel">
    <div class="section-card"><div class="section-head"><div><h3>Campaign Manager</h3><p class="muted">Create professional in-app promotional popups without changing the Android app.</p></div></div>
      <form onsubmit="createCampaign(event)"><div class="form-grid"><div><label>Title</label><input name="title" required></div><div><label>Campaign Type</label><select name="campaignType"><option value="popup">Popup</option><option value="home_banner">Home Banner</option><option value="full_screen">Full Screen</option><option value="new_feature">New Feature</option><option value="upgrade_banner">Upgrade Banner</option></select></div><div><label>Target Audience</label><select name="targetAudience"><option value="free">Free Users</option><option value="all">All Users</option><option value="premium">Premium Users</option><option value="business">Business Users</option><option value="expired">Expired Users</option></select></div><div><label>Frequency</label><select name="frequency"><option value="once">Once</option><option value="daily">Once Daily</option><option value="weekly">Once Weekly</option><option value="every_open">Every App Open</option></select></div></div><label>Subtitle</label><textarea name="subtitle" rows="2"></textarea><div class="form-grid"><div><label>Image URL</label><input name="imageUrl"></div><div><label>Button Text</label><input name="buttonText" value="View Plans"></div><div><label>Button Action</label><select name="buttonAction"><option value="open_subscription">Open Subscription</option><option value="open_feature">Open Feature</option><option value="open_url">Open URL</option><option value="dismiss">Dismiss</option></select></div><div><label>Action Value</label><input name="actionValue" placeholder="Feature key or URL"></div><div><label>Priority</label><input name="priority" type="number" value="0"></div><div><label>Maximum Displays</label><input name="maxDisplays" type="number" min="0" value="1"></div><div><label>Start Date</label><input name="startDate" type="datetime-local"></div><div><label>End Date</label><input name="endDate" type="datetime-local"></div></div><div class="inline" style="margin-top:12px"><input type="checkbox" name="active" checked> Active</div><div class="form-actions"><button class="btn btn-primary">Create Campaign</button></div></form>
    </div>
    <div class="section-card"><div class="table-wrap"><table><thead><tr><th>Title</th><th>Audience</th><th>Frequency</th><th>Status</th><th>Actions</th></tr></thead><tbody><% campaigns.forEach(c=>{ %><tr><td><strong><%=c.title%></strong><div class="mini"><%=c.subtitle%></div></td><td><%=c.targetAudience%></td><td><%=c.frequency%></td><td><span class="status <%=c.active?'on':'off'%>"><%=c.active?'ACTIVE':'INACTIVE'%></span></td><td><button class="btn btn-sm <%=c.active?'btn-danger':'btn-success'%>" onclick="toggleCampaign('<%=c._id%>',<%=!c.active%>)"><%=c.active?'Disable':'Enable'%></button> <button class="btn btn-sm btn-danger" onclick="deleteCampaign('<%=c._id%>')">Delete</button></td></tr><% }) %></tbody></table></div></div>
  </section>

  <section id="notifications" class="panel">
    <div class="section-card"><div class="section-head"><div><h3>Push Notifications</h3><p class="muted">Prepare targeted notifications. Firebase sending will be connected in the payment/app integration phase.</p></div></div><form onsubmit="createNotification(event)"><div class="form-grid"><div><label>Title</label><input name="title" required></div><div><label>Audience</label><select name="targetAudience"><option value="all">All</option><option value="free">Free</option><option value="premium">Premium</option><option value="business">Business</option><option value="expired">Expired</option></select></div><div><label>Schedule</label><input name="scheduleAt" type="datetime-local"></div><div><label>Image URL</label><input name="imageUrl"></div><div><label>Action</label><select name="actionType"><option value="none">None</option><option value="open_subscription">Open Subscription</option><option value="open_feature">Open Feature</option><option value="open_url">Open URL</option></select></div><div><label>Action Value</label><input name="actionValue" placeholder="Feature key or URL"></div><div><label>Button Text</label><input name="buttonText" placeholder="Upgrade Now"></div></div><label>Message</label><textarea name="message" rows="3" required></textarea><div class="form-actions"><button class="btn btn-primary">Save Notification</button></div></form></div>
    <div class="section-card"><div class="table-wrap"><table><thead><tr><th>Title</th><th>Audience</th><th>Status</th><th>Schedule</th><th>Actions</th></tr></thead><tbody><% notifications.forEach(n=>{ %><tr><td><strong><%=n.title%></strong><div class="mini"><%=n.message%></div></td><td><%=n.targetAudience%></td><td><span class="status <%=n.status==='sent'?'on':'warn'%>"><%=n.status.toUpperCase()%></span></td><td><%=n.scheduleAt ? new Date(n.scheduleAt).toLocaleString() : 'Not scheduled'%></td><td><select onchange="changeNotificationStatus('<%=n._id%>',this.value)"><option value="">Change status</option><option value="draft">Draft</option><option value="scheduled">Scheduled</option><option value="cancelled">Cancelled</option></select> <button class="btn btn-sm btn-success" onclick="sendNotification('<%=n._id%>')">Send</button> <button class="btn btn-sm btn-danger" onclick="deleteNotification('<%=n._id%>')">Delete</button></td></tr><% }) %></tbody></table></div></div>
  </section>

  <section id="analytics" class="panel"><div class="section-card"><h3>Subscription Analytics</h3><p class="muted">Live subscription, revenue, renewal and churn indicators.</p><div class="cards" style="margin-top:18px"><div class="card"><small>Conversion Rate</small><strong><%= stats.totalUsers ? ((stats.active/stats.totalUsers)*100).toFixed(2) : 0 %>%</strong></div><div class="card"><small>Monthly Recurring Revenue</small><strong>₹<%=stats.estimatedMrr%></strong></div><div class="card"><small>Paid Revenue This Month</small><strong>₹<%=stats.paidRevenue%></strong></div><div class="card"><small>Renewal Rate</small><strong><%=stats.renewalRate%>%</strong></div><div class="card"><small>Churn Rate</small><strong><%=stats.churnRate%>%</strong></div><div class="card"><small>Auto Renewing</small><strong><%=stats.autoRenewCount%></strong></div><div class="card"><small>Cancelled Records</small><strong><%=stats.cancelledCount%></strong></div><div class="card"><small>Net Before AI Cost</small><strong>₹<%=Math.max(0,stats.paidRevenue-Math.round(aiStats.cost))%></strong></div></div></div><div class="section-card"><h3>Recent Payment Records</h3><div class="table-wrap"><table><thead><tr><th>Date</th><th>Plan</th><th>Amount</th><th>Source</th><th>Order ID</th></tr></thead><tbody><% if(!payments.length){%><tr><td colspan="5" class="muted">No payment records yet.</td></tr><%} payments.slice(0,30).forEach(p=>{%><tr><td><%=new Date(p.paidAt).toLocaleString('en-IN')%></td><td><%=p.planKey%></td><td>₹<%=p.amount%></td><td><%=p.source%></td><td><%=p.orderId||'—'%></td></tr><%})%></tbody></table></div></div></section>

  <section id="aiusage" class="panel"><div class="section-card"><h3>AI Label Designer Usage</h3><p class="muted">Tracks API requests, estimated cost and generation performance.</p><div class="cards" style="margin-top:18px"><div class="card"><small>Requests Today</small><strong><%=aiStats.today%></strong></div><div class="card"><small>Requests This Month</small><strong><%=aiStats.month%></strong></div><div class="card"><small>Estimated AI Cost</small><strong>₹<%=Number(aiStats.cost).toFixed(2)%></strong></div><div class="card"><small>Average Generation Time</small><strong><%=aiStats.avgGenerationMs ? (aiStats.avgGenerationMs/1000).toFixed(1)+'s' : '—'%></strong></div></div></div><div class="section-card"><h3>Recent AI Requests</h3><div class="table-wrap"><table><thead><tr><th>Date</th><th>Type</th><th>Status</th><th>Model</th><th>Label Size</th><th>Time</th><th>Cost</th></tr></thead><tbody><% if(!aiUsageMonth.length){%><tr><td colspan="7" class="muted">No AI usage records yet. Android AI API can post to /api/premium/ai-usage.</td></tr><%} aiUsageMonth.slice(0,50).forEach(u=>{%><tr><td><%=new Date(u.createdAt).toLocaleString('en-IN')%></td><td><%=u.requestType%></td><td><%=u.status%></td><td><%=u.modelName%></td><td><%=u.labelSize||'—'%></td><td><%=u.generationTimeMs ? (u.generationTimeMs/1000).toFixed(1)+'s':'—'%></td><td>₹<%=Number(u.estimatedCostInr||0).toFixed(3)%></td></tr><%})%></tbody></table></div></div></section>

  <section id="settings" class="panel"><div class="section-card"><div class="section-head"><div><h3>Subscription Settings</h3><p class="muted">Global switches for the premium platform.</p></div></div><form onsubmit="saveSettings(event)"><div class="feature-checks"><label><input type="checkbox" name="premiumSystemEnabled" <%=settings?.premiumSystemEnabled?'checked':''%>> Premium System</label><label><input type="checkbox" name="aiDesignerEnabled" <%=settings?.aiDesignerEnabled?'checked':''%>> AI Designer</label><label><input type="checkbox" name="cloudBackupEnabled" <%=settings?.cloudBackupEnabled?'checked':''%>> Cloud Backup</label><label><input type="checkbox" name="teamSharingEnabled" <%=settings?.teamSharingEnabled?'checked':''%>> Team Sharing</label><label><input type="checkbox" name="popupEnabled" <%=settings?.popupEnabled?'checked':''%>> Promo Popups</label><label><input type="checkbox" name="notificationsEnabled" <%=settings?.notificationsEnabled?'checked':''%>> Notifications</label></div><div class="form-grid" style="margin-top:15px"><div><label>Cloud Retention Days</label><input name="defaultCloudRetentionDays" type="number" min="0" value="<%=settings?.defaultCloudRetentionDays || 30%>"></div><div><label>Support Email</label><input name="supportEmail" type="email" value="<%=settings?.supportEmail || ''%>"></div></div><div class="form-actions"><button class="btn btn-primary">Save Settings</button></div></form></div></section>

</main>
<script>
function openTab(id,el){document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));document.getElementById(id).classList.add('active');document.querySelectorAll('.sidebar a').forEach(x=>x.classList.remove('active'));if(el)el.classList.add('active')}
function showMessage(text,ok=true){const box=document.getElementById('message');box.className='notice '+(ok?'ok':'err');box.textContent=text;window.scrollTo({top:0,behavior:'smooth'});setTimeout(()=>box.className='notice',4000)}
async function api(url,options){const r=await fetch(url,options);const d=await r.json();if(!r.ok||!d.success)throw new Error(d.message||'Request failed');return d}
async function toggleFeature(id,enabled){try{await api('/api/premium/features/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({enabled})});showMessage('Feature updated successfully.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function savePlan(e,id){e.preventDefault();const f=new FormData(e.target);const data={};for(const [k,v] of f.entries()){if(k==='featureKeys'){data.featureKeys=data.featureKeys||[];data.featureKeys.push(v)}else data[k]=v}data.recommended=f.has('recommended');data.autoRenew=f.has('autoRenew');try{await api('/api/premium/plans/'+id,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Plan saved successfully.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function createPlan(e){e.preventDefault();const f=new FormData(e.target);const data={};for(const [k,v] of f.entries()){if(k==='featureKeys'){data.featureKeys=data.featureKeys||[];data.featureKeys.push(v)}else data[k]=v}data.autoRenew=f.has('autoRenew');data.active=f.has('active');try{await api('/api/premium/plans',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Plan created successfully.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function deletePlan(id){if(!confirm('Delete this plan? Active plans with subscribers cannot be deleted.'))return;try{await api('/api/premium/plans/'+id,{method:'DELETE'});showMessage('Plan deleted.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function createFeature(e){e.preventDefault();const f=new FormData(e.target);const data=Object.fromEntries(f.entries());data.enabled=f.has('enabled');try{await api('/api/premium/features',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Feature created successfully.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function deleteFeature(id){if(!confirm('Delete this feature? Remove it from all plans first.'))return;try{await api('/api/premium/features/'+id,{method:'DELETE'});showMessage('Feature deleted.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function createSubscription(e){e.preventDefault();const f=new FormData(e.target);const data=Object.fromEntries(f.entries());data.autoRenew=f.has('autoRenew');try{await api('/api/premium/subscriptions',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Subscription activated successfully.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function changeStatus(id,status){if(!status)return;try{await api('/api/premium/subscriptions/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});showMessage('Subscription status updated.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function extendSubscription(id){const days=Number(document.getElementById('days-'+id).value||0);if(days<=0)return showMessage('Enter valid extension days.',false);try{await api('/api/premium/subscriptions/'+id+'/extend',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({days})});showMessage('Subscription extended successfully.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
function filterSubscriptions(){const q=(document.getElementById('subSearch').value||'').toLowerCase();const status=document.getElementById('subStatus').value;document.querySelectorAll('#subscriptionTable tbody tr[data-search]').forEach(row=>{row.style.display=(!q||row.dataset.search.includes(q))&&(!status||row.dataset.status===status)?'':'none'})}

async function recordPayment(id){const amount=prompt('Enter received amount (₹):');if(amount===null)return;const orderId=prompt('Order ID / reference (optional):')||'';try{await api('/api/premium/subscriptions/'+id+'/payments',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({amount,orderId})});showMessage('Payment recorded successfully.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function deleteSubscription(id){if(!confirm('Permanently delete this subscription record?'))return;try{await api('/api/premium/subscriptions/'+id,{method:'DELETE'});showMessage('Subscription deleted.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function createCampaign(e){e.preventDefault();const f=new FormData(e.target);const data=Object.fromEntries(f.entries());data.active=f.has('active');try{await api('/api/premium/campaigns',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Campaign created successfully.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function toggleCampaign(id,active){try{await api('/api/premium/campaigns/'+id+'/toggle',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({active})});showMessage('Campaign status updated.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function deleteCampaign(id){if(!confirm('Delete this campaign?'))return;try{await api('/api/premium/campaigns/'+id,{method:'DELETE'});showMessage('Campaign deleted.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function createNotification(e){e.preventDefault();const data=Object.fromEntries(new FormData(e.target).entries());try{await api('/api/premium/notifications',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Notification saved successfully.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function changeNotificationStatus(id,status){if(!status)return;try{await api('/api/premium/notifications/'+id+'/status',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({status})});showMessage('Notification status updated.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function sendNotification(id){if(!confirm('Mark this notification as sent? Firebase live delivery will be connected in Phase 2.'))return;try{const d=await api('/api/premium/notifications/'+id+'/send',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({})});showMessage(d.message||'Notification marked as sent.');setTimeout(()=>location.reload(),500)}catch(e){showMessage(e.message,false)}}
async function deleteNotification(id){if(!confirm('Delete this notification?'))return;try{await api('/api/premium/notifications/'+id,{method:'DELETE'});showMessage('Notification deleted.');setTimeout(()=>location.reload(),500)}catch(err){showMessage(err.message,false)}}
async function saveSettings(e){e.preventDefault();const f=new FormData(e.target);const names=['premiumSystemEnabled','aiDesignerEnabled','cloudBackupEnabled','teamSharingEnabled','popupEnabled','notificationsEnabled'];const data=Object.fromEntries(f.entries());names.forEach(n=>data[n]=f.has(n));try{await api('/api/premium/settings',{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)});showMessage('Settings saved successfully.')}catch(err){showMessage(err.message,false)}}

const date=document.querySelector('input[name="expiryDate"]');if(date){const d=new Date();d.setMonth(d.getMonth()+1);date.value=d.toISOString().slice(0,10)}
</script>
</body></html>
